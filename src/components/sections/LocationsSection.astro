---
import { locations } from "../../data/locations.js";
---

<section id="ubicaciones" class="py-16 sm:py-20 lg:py-24 relative text-[var(--c-heading)] overflow-hidden">
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-10 left-1/4 w-72 h-72 bg-sky-200/40 rounded-full blur-[120px]"></div>
    <div class="absolute bottom-10 right-1/4 w-80 h-80 bg-blue-200/30 rounded-full blur-[100px]"></div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">

    <div class="text-center mb-10 sm:mb-16 max-w-2xl mx-auto" data-animate="fade-up">
      <p class="text-blue-600 text-sm font-semibold tracking-[0.25em] uppercase mb-3">Ubicaciones</p>
      <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-[var(--c-heading)] mb-4">Encuéntranos</h2>
      <p class="text-[var(--c-body-text)] text-lg">
        Visítanos en nuestras sedes para conocer nuestra gama completa de productos.
      </p>
    </div>

    <div class="space-y-12">
      {locations.map((loc, idx) => (
        <div
          class="bg-[var(--c-card-bg)] border border-[var(--c-card-border)] shadow-md rounded-2xl overflow-hidden hover:shadow-xl hover:shadow-blue-200/40 transition-all duration-300"
          data-animate="fade-up"
          data-animate-delay="100"
        >

          <div class="grid grid-cols-1 lg:grid-cols-2">

            <div class="aspect-video lg:aspect-auto lg:min-h-[360px] bg-slate-100 relative">
              {loc.embedUrl ? (
                <iframe
                  src={loc.embedUrl}
                  class="w-full h-full border-0"
                  allowfullscreen=""
                  loading="lazy"
                  referrerpolicy="no-referrer-when-downgrade"
                  title={`Mapa - ${loc.name}`}
                ></iframe>
              ) : (
                <div class="w-full h-full flex flex-col items-center justify-center gap-3 text-slate-500">
                  <svg class="w-10 h-10 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                  </svg>
                  <p class="text-sm">Mapa próximamente</p>
                </div>
              )}
            </div>

            <div
              class="aspect-video lg:aspect-auto lg:min-h-[360px] bg-slate-100 relative overflow-hidden border-t lg:border-t-0 lg:border-l border-slate-200"
              data-location-carousel
              data-interval="4500"
            >
              {loc.images && loc.images.length > 0 ? (
                <>
                  {loc.images.map((img, i) => (
                    <div
                      class={`location-slide absolute inset-0 transition-opacity duration-700 ${i === 0 ? "opacity-100" : "opacity-0"}`}
                    >
                      <img
                        src={img}
                        alt={`${loc.name} - imagen ${i + 1}`}
                        class="w-full h-full object-cover"
                        loading="lazy"
                        onerror={`this.style.display='none'; this.nextElementSibling.style.display='flex'`}
                      />
                      <div class="absolute inset-0 hidden flex-col items-center justify-center gap-2 text-slate-500 bg-gradient-to-br from-slate-100 to-slate-200">
                        <svg class="w-10 h-10 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
                        </svg>
                        <p class="text-xs">Imagen {i + 1}</p>
                      </div>
                    </div>
                  ))}

                  <div class="absolute inset-0 bg-gradient-to-t from-[#0d1b4b]/40 via-transparent to-transparent pointer-events-none"></div>

                  {loc.images.length > 1 && (
                    <div class="absolute bottom-4 left-1/2 -translate-x-1/2 flex gap-2 z-10">
                      {loc.images.map((_, i) => (
                        <button
                          class={`location-dot rounded-full transition-all duration-300 ${i === 0 ? "bg-blue-600 w-6 h-2" : "bg-white/70 hover:bg-white w-2 h-2"}`}
                          aria-label={`Imagen ${i + 1}`}
                        ></button>
                      ))}
                    </div>
                  )}
                </>
              ) : (
                <div class="w-full h-full flex flex-col items-center justify-center gap-3 text-slate-500">
                  <svg class="w-10 h-10 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5z" />
                  </svg>
                  <p class="text-sm">Imágenes próximamente</p>
                </div>
              )}
            </div>

          </div>

          <div class="p-6 border-t border-slate-200">
            <h3 class="text-[var(--c-heading)] font-semibold text-lg mb-3">{loc.name}</h3>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-3 text-[var(--c-body-text)] text-sm mb-5">
              <p class="flex items-start gap-2">
                <svg class="w-4 h-4 text-blue-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                </svg>
                {loc.address}
              </p>
              <p class="flex items-center gap-2">
                <svg class="w-4 h-4 text-blue-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
                </svg>
                {loc.phone}
              </p>
              <p class="flex items-center gap-2">
                <svg class="w-4 h-4 text-blue-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                {loc.hours}
              </p>
            </div>

            {loc.mapUrl ? (
              <a
                href={loc.mapUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 text-blue-600 hover:text-sky-500 text-sm font-medium transition-colors duration-200"
              >
                Cómo llegar
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
                </svg>
              </a>
            ) : (
              <p class="text-slate-400 text-xs italic">Enlace a mapa próximamente</p>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLElement>("[data-location-carousel]").forEach((carousel) => {
    const slides = carousel.querySelectorAll<HTMLElement>(".location-slide");
    const dots = carousel.querySelectorAll<HTMLElement>(".location-dot");
    if (slides.length <= 1) return;

    const interval = parseInt(carousel.dataset.interval || "4500", 10);
    let current = 0;
    let timer: number;

    const goTo = (index: number) => {
      slides[current].classList.remove("opacity-100");
      slides[current].classList.add("opacity-0");
      dots[current]?.classList.remove("bg-blue-600", "w-6");
      dots[current]?.classList.add("bg-white/70", "hover:bg-white", "w-2");

      current = (index + slides.length) % slides.length;

      slides[current].classList.remove("opacity-0");
      slides[current].classList.add("opacity-100");
      dots[current]?.classList.add("bg-blue-600", "w-6");
      dots[current]?.classList.remove("bg-white/70", "hover:bg-white", "w-2");
    };

    const next = () => goTo(current + 1);

    const start = () => {
      timer = window.setInterval(next, interval);
    };

    const stop = () => {
      window.clearInterval(timer);
    };

    dots.forEach((dot, i) => {
      dot.addEventListener("click", () => {
        stop();
        goTo(i);
        start();
      });
    });

    carousel.addEventListener("mouseenter", stop);
    carousel.addEventListener("mouseleave", start);

    start();
  });
</script>
