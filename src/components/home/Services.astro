---
import { services } from "../../data/services.js";

const icons = {
  diagnostic: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"/></svg>`,
  supplies: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z"/></svg>`,
  lab: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M5 14.5l-1.975 5.259A.75.75 0 003.735 21h16.53a.75.75 0 00.71-1.241L19.8 15.3M5 14.5h14.8"/></svg>`,
  hospital: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 0h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008z"/></svg>`,
  support: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9 5.25h.008v.008H12v-.008z"/></svg>`,
  maintenance: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17l-5.1-5.1a1.5 1.5 0 010-2.12l.88-.88a1.5 1.5 0 012.12 0l.88.88a1.5 1.5 0 002.12 0l3.17-3.17a4.5 4.5 0 016.36 6.36l-3.17 3.17a1.5 1.5 0 000 2.12l.88.88a1.5 1.5 0 010 2.12l-.88.88a1.5 1.5 0 01-2.12 0l-5.1-5.1z"/></svg>`,
};
---

<section id="servicios" class="py-24 relative text-[var(--c-heading)] overflow-hidden">
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-1/2 left-0 w-72 h-72 bg-blue-300/30 rounded-full blur-[120px]"></div>
    <div class="absolute top-1/2 right-0 w-80 h-80 bg-sky-300/40 rounded-full blur-[100px]"></div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">

    <div class="text-center mb-16 max-w-2xl mx-auto" data-animate="fade-up">
      <p class="text-blue-600 text-sm font-semibold tracking-[0.25em] uppercase mb-3">Servicios</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-[var(--c-heading)] mb-4">
        Soluciones integrales para el
        <span class="bg-gradient-to-r from-blue-600 to-sky-500 bg-clip-text text-transparent">
          sector salud
        </span>
      </h2>
      <p class="text-[var(--c-body-text)] text-lg">
        Ofrecemos productos y servicios especializados para todas las necesidades médicas.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {services.map((service, i) => (
        <div
          class="group relative bg-[var(--c-card-bg)] border border-[var(--c-card-border)] shadow-sm rounded-2xl p-7 hover:shadow-xl hover:shadow-blue-300/30 hover:-translate-y-1 transition-all duration-300 overflow-hidden"
          data-animate="fade-up"
          data-animate-delay={((i % 3) + 1) * 100}
        >
          <div class="absolute top-0 right-0 w-32 h-32 bg-blue-100 rounded-full blur-2xl -translate-y-1/2 translate-x-1/2 group-hover:bg-blue-200 transition-colors duration-500"></div>

          <div class="relative z-10">
            <div class="w-12 h-12 bg-gradient-to-br from-blue-100 to-sky-100 text-blue-600 rounded-xl flex items-center justify-center mb-5 group-hover:from-blue-600 group-hover:to-sky-500 group-hover:text-white transition-all duration-300">
              <Fragment set:html={icons[service.icon]} />
            </div>
            <h3 class="text-[var(--c-heading)] font-semibold text-lg mb-2">{service.title}</h3>
            <p class="text-[var(--c-body-text)] text-sm leading-relaxed">{service.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
