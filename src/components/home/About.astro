---
const values = [
  {
    title: "Misión",
    text: "Proveer productos médicos de alta calidad que contribuyan a mejorar la atención de salud.",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/></svg>`,
  },
  {
    title: "Visión",
    text: "Ser referentes en la distribución de tecnología médica en la región.",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`,
  },
  {
    title: "Calidad",
    text: "Productos con certificaciones internacionales y estándares de excelencia.",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.746 3.746 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.746 3.746 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.745 3.745 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z"/></svg>`,
  },
  {
    title: "Soporte",
    text: "Asesoría técnica y acompañamiento permanente a nuestros clientes.",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 01-.825-.242m9.345-8.334a2.126 2.126 0 00-.476-.095 48.64 48.64 0 00-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0011.25 3c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V21l4.155-4.155"/></svg>`,
  },
];
---

<section id="nosotros" class="py-16 sm:py-20 lg:py-24 relative text-[var(--c-heading)] overflow-hidden">
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-20 -left-32 w-96 h-96 bg-sky-200/40 rounded-full blur-[120px]"></div>
    <div class="absolute bottom-20 -right-32 w-80 h-80 bg-blue-200/30 rounded-full blur-[100px]"></div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center">

      <div data-animate="fade-right">
        <p class="text-blue-600 text-sm font-semibold tracking-[0.25em] uppercase mb-3">
          Sobre nosotros
        </p>
        <h2 class="text-2xl sm:text-3xl lg:text-5xl font-bold text-[var(--c-heading)] leading-tight mb-5 sm:mb-6">
          Innovación al servicio
          <span class="bg-gradient-to-r from-blue-600 to-sky-500 bg-clip-text text-transparent">
            de la salud
          </span>
        </h2>
        <p class="text-[var(--c-body-text)] text-lg leading-relaxed mb-6">
          Corporación Larisa es una empresa dedicada a la distribución y comercialización
          de productos médicos de alta calidad. Trabajamos con los mejores fabricantes
          para llevar tecnología de punta a los profesionales de la salud.
        </p>
        <p class="text-[var(--c-body-text)] leading-relaxed">
          Nuestra misión es contribuir al bienestar de los pacientes proporcionando
          a los equipos médicos las herramientas que necesitan para ofrecer una
          atención de excelencia.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {values.map((card, i) => (
          <div
            class="group bg-[var(--c-card-bg)] border border-[var(--c-card-border)] shadow-sm rounded-2xl p-6 hover:shadow-lg hover:shadow-blue-200/50 hover:border-blue-300 hover:-translate-y-1 transition-all duration-300"
            data-animate="fade-up"
            data-animate-delay={(i + 1) * 100}
          >
            <div class="w-10 h-10 bg-blue-50 text-blue-600 rounded-lg flex items-center justify-center mb-4 group-hover:bg-blue-600 group-hover:text-white transition-colors duration-300">
              <Fragment set:html={card.icon} />
            </div>
            <h3 class="text-[var(--c-heading)] font-semibold text-sm mb-2">{card.title}</h3>
            <p class="text-[var(--c-body-text)] text-sm leading-relaxed">{card.text}</p>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>
