---
// Separador con tres ondas ECG estáticas casi invisibles (camufladas con el fondo)
// y una estela brillante que recorre todo el trazo revelando las formas a su paso.
---

<div class="w-full py-10 sm:py-14">
  <svg
    viewBox="0 0 1600 80"
    class="w-full"
    preserveAspectRatio="xMidYMid meet"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
  >
    <defs>
      <!-- Glow intenso para la estela: blur grande + blur pequeño superpuestos -->
      <filter id="ecg-stela-glow" x="-5%" y="-50%" width="110%" height="200%">
        <feGaussianBlur stdDeviation="5" result="blur-far" />
        <feGaussianBlur in="SourceGraphic" stdDeviation="2" result="blur-near" />
        <feMerge>
          <feMergeNode in="blur-far" />
          <feMergeNode in="blur-near" />
          <feMergeNode in="SourceGraphic" />
        </feMerge>
      </filter>
    </defs>

    <!-- Trazo ECG estático: 3 complejos QRS sobre línea base, casi invisible. -->
    <path
      d="M 0,40 L 360,40 L 368,30 L 376,50 L 384,10 L 392,70 L 400,26 L 408,40 L 770,40 L 778,30 L 786,50 L 794,10 L 802,70 L 810,26 L 818,40 L 1180,40 L 1188,30 L 1196,50 L 1204,10 L 1212,70 L 1220,26 L 1228,40 L 1600,40"
      stroke="#38BDF8"
      stroke-opacity="0.08"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    />

    <!-- Estela: trazo brillante con dasharray que recorre el mismo path -->
    <path
      d="M 0,40 L 360,40 L 368,30 L 376,50 L 384,10 L 392,70 L 400,26 L 408,40 L 770,40 L 778,30 L 786,50 L 794,10 L 802,70 L 810,26 L 818,40 L 1180,40 L 1188,30 L 1196,50 L 1204,10 L 1212,70 L 1220,26 L 1228,40 L 1600,40"
      stroke="#38BDF8"
      stroke-width="2.4"
      fill="none"
      stroke-linecap="round"
      stroke-linejoin="round"
      pathLength="100"
      stroke-dasharray="8 92"
      filter="url(#ecg-stela-glow)"
    >
      <animate
        attributeName="stroke-dashoffset"
        from="0"
        to="100"
        dur="6s"
        repeatCount="indefinite"
      />
    </path>
  </svg>
</div>
