---
import "../../styles/global.css";
import Navbar from "./Navbar.astro";
import Footer from "./Footer.astro";
import WhatsAppButton from "../common/WhatsAppButton.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Corporación Larisa — Productos Médicos",
  description = "Soluciones médicas de alta tecnología. Equipos, insumos y dispositivos médicos certificados para profesionales de la salud.",
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#020617" />
    <link rel="icon" type="image/png" href="/images/logo/Imagotipo Corp Larisa SA-18.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class="antialiased overflow-x-hidden">
    <Navbar />
    <main>
      <slot />
    </main>
    <Footer />
    <WhatsAppButton />

    <script>
      const initAnimations = () => {
        const elements = document.querySelectorAll<HTMLElement>("[data-animate]");
        if (!elements.length) return;

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: "0px 0px -80px 0px" }
        );

        elements.forEach((el) => observer.observe(el));
      };

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initAnimations);
      } else {
        initAnimations();
      }
    </script>
  </body>
</html>
