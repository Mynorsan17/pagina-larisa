---
import { navLinks } from "../../data/navigation.js";
import { site } from "../../data/site.js";
---

<header
  id="main-nav"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 border-b border-white/0"
>
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-20 flex items-center justify-between">
    <a href="#inicio" class="flex items-center gap-3 shrink-0">
      <img
        src={site.logo.navbar}
        alt={site.name}
        class="navbar-logo-light h-16 w-auto object-contain drop-shadow-lg"
      />
      <img
        src={site.logo.navbarDark}
        alt={site.name}
        class="navbar-logo-dark h-16 w-auto object-contain drop-shadow-lg"
      />
    </a>

    <ul class="hidden lg:flex items-center gap-1">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="nav-link px-4 py-2 text-sm font-medium text-[var(--c-body-text)] rounded-lg transition-colors duration-200"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <a
      href="#contacto"
      class="hidden lg:inline-flex items-center gap-2 bg-blue-brand hover:bg-blue-dark text-white text-sm font-semibold px-5 py-2.5 rounded-lg transition-all duration-200 hover:shadow-lg hover:shadow-blue-brand/25"
    >
      Contáctanos
    </a>

    <button
      id="menu-toggle"
      class="lg:hidden flex flex-col gap-[5px] p-2 group"
      aria-label="Abrir menú"
    >
      <span class="menu-line w-6 h-[2px] bg-[var(--c-body-text)] block transition-all duration-300 origin-center group-[.open]:translate-y-[7px] group-[.open]:rotate-45"></span>
      <span class="menu-line w-6 h-[2px] bg-[var(--c-body-text)] block transition-all duration-300 group-[.open]:opacity-0"></span>
      <span class="menu-line w-6 h-[2px] bg-[var(--c-body-text)] block transition-all duration-300 origin-center group-[.open]:-translate-y-[7px] group-[.open]:-rotate-45"></span>
    </button>
  </nav>

  <div
    id="mobile-menu"
    class="hidden lg:hidden backdrop-blur-xl border-t"
    style="background-color: var(--c-navbar-bg); border-top-color: var(--c-navbar-border);"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-6">
      <ul class="flex flex-col gap-1">
        {navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="nav-link mobile-link block text-[var(--c-body-text)] font-medium text-base py-3 px-4 rounded-lg transition-colors duration-200"
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
      <a
        href="#contacto"
        class="mobile-link mt-4 block text-center bg-blue-brand hover:bg-blue-dark text-white font-semibold py-3 px-5 rounded-lg transition-colors duration-200"
      >
        Contáctanos
      </a>
    </div>
  </div>
</header>

<script>
  const nav = document.getElementById("main-nav");
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");

  toggle?.addEventListener("click", () => {
    toggle.classList.toggle("open");
    menu?.classList.toggle("hidden");
  });

  menu?.querySelectorAll(".mobile-link").forEach((link) => {
    link.addEventListener("click", () => {
      toggle?.classList.remove("open");
      menu?.classList.add("hidden");
    });
  });

  window.addEventListener("scroll", () => {
    if (window.scrollY > 50) {
      nav?.classList.add("nav-scrolled");
      nav?.classList.remove("border-white/0");
    } else {
      nav?.classList.remove("nav-scrolled");
      nav?.classList.add("border-white/0");
    }
  });
</script>
